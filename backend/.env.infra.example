# Copy to backend/.env (or export these vars in your shell)
POSTGRES_URL=postgresql+psycopg2://prestocks:prestocks@localhost:5432/prestocks
REDIS_URL=redis://localhost:6379/0
INFRA_HISTORY_DAYS=90
INFRA_NEWS_LIMIT=50
APP_ENV=development

# Provider keys (fallbacks)
FINNHUB_API_KEY=
FRED_API_KEY=
SEC_USER_AGENT=PreStocksDataInfra/1.2 admin@prestocks.local

# Retry / backoff controls
INFRA_PIPELINE_MAX_ATTEMPTS=3
INFRA_PIPELINE_BACKOFF_SECONDS=2

# Alerting
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=infra-alerts@prestocks.local
ALERT_TO_EMAIL=

